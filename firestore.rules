rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: organizations
    // Fields: name (string), code (string), adminId (string), createdAt (timestamp), settings (map)
    //
    // Collection: users
    // Fields: uid (string), email (string), displayName (string), role (string), orgId (string), supervisorId (string), status (string)
    //
    // Collection: reports
    // Fields: title (string), description (string), authorId (string), orgId (string), status (string), attachments (list), reviewedBy (string)
    //
    // Collection: tasks
    // Fields: title (string), assigneeId (string), creatorId (string), orgId (string), status (string), priority (string)
    //
    // Collection: auditLogs
    // Fields: action (string), actorId (string), orgId (string), targetId (string), details (map), timestamp (timestamp)
    //
    // Collection: comments
    // Fields: parentId (string), authorId (string), authorName (string), text (string), createdAt (timestamp)
    //
    // Collection: reportTypes
    // Fields: name (string), orgId (string), locationRequired (bool), description (string)
    //
    // Collection: webhooks
    // Fields: orgId (string), url (string), events (list), active (bool), createdAt (timestamp)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "omulebrianfredrick@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'SUPER_ADMIN')
      );
    }

    function isOrgAdmin(orgId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (getUserData().role == 'ORG_ADMIN' || getUserData().role == 'SUPER_ADMIN') && 
             getUserData().orgId == orgId;
    }

    function isInSameOrg(orgId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().orgId == orgId;
    }

    function isSupervisorOf(subordinateId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(subordinateId)) &&
             get(/databases/$(database)/documents/users/$(subordinateId)).data.supervisorId == request.auth.uid;
    }

    function hasRole(roles) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role in roles;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUrl(url) {
      return url is string && url.size() < 500 && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidOrganization(data) {
      return hasOnlyAllowedFields(['name', 'code', 'adminId', 'createdAt', 'settings']) &&
             hasRequiredFields(['name', 'code', 'adminId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.code is string && data.code.size() > 0 && data.code.size() < 20 &&
             data.adminId is string &&
             data.settings is map;
    }

    function isValidUser(data, userId) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'role', 'orgId', 'supervisorId', 'status', 'createdAt']) &&
             hasRequiredFields(['uid', 'email', 'role', 'orgId']) &&
             data.uid is string && data.uid == userId &&
             data.email is string && data.email.size() < 100 &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.role in ['SUPER_ADMIN', 'ORG_ADMIN', 'EXECUTIVE', 'HR', 'IT_STAFF', 'MANAGER', 'SUPERVISOR', 'WORKER'] &&
             data.orgId is string &&
             data.status in ['active', 'pending_approval', 'inactive'];
    }

    function isValidReport(data) {
      return hasOnlyAllowedFields(['title', 'typeId', 'description', 'challenges', 'pendingTasks', 'authorId', 'orgId', 'status', 'attachments', 'location', 'createdAt', 'reviewedBy', 'reviewComment', 'aiSummary', 'aiAnalysis', 'updatedAt', 'history', 'taskId']) &&
             hasRequiredFields(['title', 'authorId', 'orgId', 'status']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() < 5000 &&
             (!('challenges' in data) || (data.challenges is string && data.challenges.size() < 2000)) &&
             (!('pendingTasks' in data) || (data.pendingTasks is string && data.pendingTasks.size() < 2000)) &&
             data.authorId is string &&
             data.orgId is string &&
             data.status in ['draft', 'submitted', 'approved', 'rejected', 'revision_requested'] &&
             data.attachments is list &&
             (!('reviewComment' in data) || (data.reviewComment is string && data.reviewComment.size() < 2000)) &&
             (!('aiSummary' in data) || (data.aiSummary is string && data.aiSummary.size() < 5000));
    }

    function isValidTask(data) {
      return hasOnlyAllowedFields(['title', 'description', 'assigneeIds', 'leadAssigneeId', 'creatorId', 'orgId', 'deadline', 'status', 'priority', 'checklist', 'attachments', 'createdAt', 'updatedAt']) &&
             hasRequiredFields(['title', 'assigneeIds', 'creatorId', 'orgId', 'status']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() < 2000 &&
             data.assigneeIds is list &&
             data.creatorId is string &&
             data.orgId is string &&
             data.status in ['pending', 'in_progress', 'submitted', 'approved', 'rejected', 'overdue', 'completed'] &&
             data.priority in ['low', 'medium', 'high', 'urgent'];
    }

    function isValidComment(data) {
      return hasOnlyAllowedFields(['parentId', 'authorId', 'authorName', 'text', 'createdAt']) &&
             hasRequiredFields(['parentId', 'authorId', 'text', 'createdAt']) &&
             data.parentId is string &&
             data.authorId is string &&
             data.authorName is string && data.authorName.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 2000;
    }

    function isValidWebhook(data) {
      return hasOnlyAllowedFields(['orgId', 'url', 'events', 'active', 'createdAt']) &&
             hasRequiredFields(['orgId', 'url', 'events', 'active']) &&
             data.orgId is string &&
             isValidUrl(data.url) &&
             data.events is list &&
             data.active is bool;
    }

    function isValidPublicContent(data) {
      return hasOnlyAllowedFields(['companyName', 'description', 'activities', 'news', 'gallery', 'updatedAt']) &&
             hasRequiredFields(['companyName', 'description']) &&
             data.companyName is string && data.companyName.size() > 0 && data.companyName.size() < 200 &&
             data.description is string && data.description.size() < 10000 &&
             (!('activities' in data) || data.activities is list) &&
             (!('news' in data) || data.news is list) &&
             (!('gallery' in data) || data.gallery is list);
    }

    function isValidReportType(data) {
      return hasOnlyAllowedFields(['name', 'orgId', 'locationRequired', 'description', 'createdAt']) &&
             hasRequiredFields(['name', 'orgId', 'locationRequired']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.orgId is string &&
             data.locationRequired is bool &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Organizations
    match /organizations/{orgId} {
      allow read: if isAuthenticated() && (isInSameOrg(orgId) || isAdmin());
      allow create: if isAuthenticated() && isValidOrganization(request.resource.data);
      allow update: if isOrgAdmin(orgId) && isValidOrganization(request.resource.data);
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) || 
        isAdmin() ||
        (isInSameOrg(resource.data.orgId) && hasRole(['MANAGER', 'SUPERVISOR', 'ORG_ADMIN', 'HR']))
      );
      allow create: if isAuthenticated() && isValidUser(request.resource.data, userId) && (
        request.resource.data.role == 'WORKER' || 
        request.resource.data.role == 'ORG_ADMIN' || // Allow initial org setup
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || 
        isOrgAdmin(resource.data.orgId) || 
        isAdmin()
      ) && isValidUser(request.resource.data, userId);
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isAuthenticated() && (
        isOwner(resource.data.authorId) || 
        isSupervisorOf(resource.data.authorId) ||
        (hasRole(['MANAGER', 'HR', 'EXECUTIVE', 'ORG_ADMIN', 'SUPER_ADMIN']) && isInSameOrg(resource.data.orgId))
      );
      allow create: if isAuthenticated() && isInSameOrg(request.resource.data.orgId) && 
                    isOwner(request.resource.data.authorId) && isValidReport(request.resource.data);
      allow update: if isAuthenticated() && (
        (isOwner(resource.data.authorId) && resource.data.status in ['draft', 'revision_requested'] && 
         request.resource.data.authorId == resource.data.authorId && request.resource.data.orgId == resource.data.orgId) ||
        isSupervisorOf(resource.data.authorId) ||
        (hasRole(['MANAGER', 'ORG_ADMIN']) && isInSameOrg(resource.data.orgId))
      ) && isValidReport(request.resource.data);
    }

    // Report Types
    match /reportTypes/{typeId} {
      allow read: if isAuthenticated() && (isInSameOrg(resource.data.orgId) || isAdmin());
      allow create: if isAuthenticated() && isOrgAdmin(request.resource.data.orgId) && isValidReportType(request.resource.data);
      allow update: if isAuthenticated() && isOrgAdmin(resource.data.orgId) && isValidReportType(request.resource.data);
      allow delete: if isAuthenticated() && isOrgAdmin(resource.data.orgId);
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.assigneeIds || 
        isOwner(resource.data.creatorId) ||
        isInSameOrg(resource.data.orgId)
      );
      allow create: if isAuthenticated() && hasRole(['SUPERVISOR', 'MANAGER', 'ORG_ADMIN', 'SUPER_ADMIN']) && 
                    isInSameOrg(request.resource.data.orgId) && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && (
        (request.auth.uid in resource.data.assigneeIds && request.resource.data.creatorId == resource.data.creatorId) || 
        isOwner(resource.data.creatorId) ||
        isOrgAdmin(resource.data.orgId)
      ) && isValidTask(request.resource.data);
    }

    // Notifications
    match /notifications/{notifId} {
      allow read, update: if isOwner(resource.data.recipientId);
      allow create: if isAuthenticated();
    }

    // Audit Logs
    match /auditLogs/{logId} {
      allow read: if isAuthenticated() && (isOrgAdmin(resource.data.orgId) || isAdmin());
      allow create: if isAuthenticated();
    }

    // Comments
    match /comments/{commentId} {
      allow read: if isAuthenticated(); // Contextual access should be checked based on parent, but for now simple
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow delete: if isAuthenticated() && (isOwner(resource.data.authorId) || isAdmin());
    }

    // Webhooks
    match /webhooks/{webhookId} {
      allow read: if isAuthenticated() && (isOrgAdmin(resource.data.orgId) || isAdmin());
      allow create: if isOrgAdmin(request.resource.data.orgId) && isValidWebhook(request.resource.data);
      allow update: if isOrgAdmin(resource.data.orgId) && isValidWebhook(request.resource.data);
      allow delete: if isOrgAdmin(resource.data.orgId);
    }

    // Public Content
    match /publicContent/{contentId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPublicContent(request.resource.data);
    }
  }
}
